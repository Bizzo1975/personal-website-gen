#!/bin/bash

# Personal Website Startup Script
# This script handles all initialization and startup tasks for the personal website project

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}=====================================================${NC}"
echo -e "${BLUE}  Personal Website Startup Script${NC}"
echo -e "${BLUE}=====================================================${NC}"

# Function to check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Function to check Node.js version
check_node_version() {
    if command_exists node; then
        NODE_VERSION=$(node --version | cut -d'v' -f2 | cut -d'.' -f1)
        if [ "$NODE_VERSION" -ge 18 ]; then
            echo -e "${GREEN}✓ Node.js version $(node --version) is compatible${NC}"
            return 0
        else
            echo -e "${RED}✗ Node.js version $(node --version) is too old. Requires v18+${NC}"
            return 1
        fi
    else
        echo -e "${RED}✗ Node.js is not installed${NC}"
        return 1
    fi
}

# Function to setup environment
setup_environment() {
    echo -e "\n${YELLOW}Setting up environment...${NC}"
    
    if [ ! -f .env.local ]; then
        echo -e "${YELLOW}Creating .env.local file with new port configuration...${NC}"
        
        # Generate secure NextAuth secret
        if command_exists openssl; then
            NEXTAUTH_SECRET=$(openssl rand -hex 32)
        else
            echo -e "${YELLOW}OpenSSL not found, using fallback method for secret generation${NC}"
            NEXTAUTH_SECRET=$(date +%s | sha256sum | base64 | head -c 64)
        fi
        
        cat > .env.local << EOF
# Port Configuration
FRONTEND_PORT=3006
BACKEND_PORT=4006
DATABASE_PORT=5436

# Base URLs
FRONTEND_URL=http://localhost:3006
BACKEND_URL=http://localhost:4006
API_URL=http://localhost:3006/api

# MongoDB Configuration
MONGODB_URI=mongodb+srv://webuidb:Skyler01@cluster0.7us70qf.mongodb.net/?retryWrites=true&w=majority
DB_NAME=personal_website

# NextAuth Configuration
NEXTAUTH_SECRET=${NEXTAUTH_SECRET}
NEXTAUTH_URL=http://localhost:3006
NEXTAUTH_URL_INTERNAL=http://localhost:3006

# Development flags
NODE_ENV=development
MOCK_DATA=true
DATABASE_TYPE=mongodb

# Upload Configuration
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880
EOF
        echo -e "${GREEN}✓ .env.local created successfully with port 3006 configuration${NC}"
    else
        echo -e "${GREEN}✓ .env.local already exists${NC}"
        echo -e "${YELLOW}Note: Please verify it contains the new port configuration (FRONTEND_PORT=3006)${NC}"
    fi
}

# Function to install dependencies
install_dependencies() {
    echo -e "\n${YELLOW}Installing dependencies...${NC}"
    
    if [ -f package-lock.json ]; then
        npm ci
    else
        npm install
    fi
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✓ Dependencies installed successfully${NC}"
    else
        echo -e "${RED}✗ Failed to install dependencies${NC}"
        exit 1
    fi
    
    # Check for cross-env dependency (for Windows compatibility)
    echo -e "\n${YELLOW}Checking for cross-env dependency...${NC}"
    if npm list cross-env >/dev/null 2>&1; then
        echo -e "${GREEN}✓ cross-env already installed${NC}"
    else
        echo -e "${YELLOW}Installing cross-env for cross-platform compatibility...${NC}"
        npm install --save-dev cross-env
        echo -e "${GREEN}✓ cross-env installed${NC}"
    fi
}

# Function to setup images
setup_images() {
    echo -e "\n${YELLOW}Setting up placeholder images...${NC}"
    
    if [ -f scripts/setup/ensure-placeholder-images.js ]; then
        node scripts/setup/ensure-placeholder-images.js
        echo -e "${GREEN}✓ Placeholder images setup complete${NC}"
    else
        echo -e "${YELLOW}! Placeholder image script not found, skipping...${NC}"
    fi
}

# Function to clear cache
clear_cache() {
    echo -e "\n${YELLOW}Clearing Next.js cache...${NC}"
    
    if command_exists rimraf; then
        rimraf .next
    else
        rm -rf .next
    fi
    
    echo -e "${GREEN}✓ Cache cleared${NC}"
}

# Function to check database connection
check_database() {
    echo -e "\n${YELLOW}Checking database connection...${NC}"
    
    if [ -f testing/test-db-connection.js ]; then
        node --env-file=.env.local testing/test-db-connection.js 2>/dev/null
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}✓ Database connection successful${NC}"
        else
            echo -e "${YELLOW}! Database connection failed - will use mock data${NC}"
        fi
    else
        echo -e "${YELLOW}! Database test script not found, skipping connection test${NC}"
    fi
}

# Function to run tests
run_tests() {
    echo -e "\n${YELLOW}Running quick health check tests...${NC}"
    
    # Check if test script exists
    if [ -f package.json ] && grep -q '"test"' package.json; then
        npm run test:ci >/dev/null 2>&1
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}✓ Tests passed${NC}"
        else
            echo -e "${YELLOW}! Some tests failed, but continuing startup${NC}"
        fi
    else
        echo -e "${YELLOW}! Test script not found, skipping tests${NC}"
    fi
}

# Function to start development server
start_server() {
    echo -e "\n${YELLOW}Starting development server...${NC}"
    echo -e "${GREEN}Server will be available at: http://localhost:3006${NC}"
    echo -e "${GREEN}Admin panel will be available at: http://localhost:3006/admin${NC}"
    echo -e "${BLUE}Press Ctrl+C to stop the server${NC}"
    echo -e "\n${BLUE}=====================================================${NC}"
    
    # Start the development server with mock data
    npm run dev:mock
}

# Function to display help
show_help() {
    echo -e "\n${BLUE}Usage: ./startup-all [options]${NC}"
    echo -e "Options:"
    echo -e "  --help, -h     Show this help message"
    echo -e "  --no-tests     Skip running tests"
    echo -e "  --prod         Start in production mode"
    echo -e "  --setup-only   Only run setup tasks, don't start server"
    echo -e ""
    echo -e "Examples:"
    echo -e "  ./startup-all                 # Full startup with tests on port 3006"
    echo -e "  ./startup-all --no-tests      # Skip tests"
    echo -e "  ./startup-all --setup-only    # Setup only"
    echo -e ""
    echo -e "Port Configuration:"
    echo -e "  Frontend: 3006 (changed from 3000)"
    echo -e "  Backend:  4006 (for future API separation)"
    echo -e "  Database: 5436 (PostgreSQL port, currently using MongoDB)"
    echo -e ""
}

# Main startup sequence
main() {
    local SKIP_TESTS=false
    local PROD_MODE=false
    local SETUP_ONLY=false
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --help|-h)
                show_help
                exit 0
                ;;
            --no-tests)
                SKIP_TESTS=true
                shift
                ;;
            --prod)
                PROD_MODE=true
                shift
                ;;
            --setup-only)
                SETUP_ONLY=true
                shift
                ;;
            *)
                echo -e "${RED}Unknown option: $1${NC}"
                show_help
                exit 1
                ;;
        esac
    done
    
    # Check prerequisites
    echo -e "${YELLOW}Checking prerequisites...${NC}"
    
    if ! check_node_version; then
        echo -e "${RED}Please install Node.js v18 or higher${NC}"
        exit 1
    fi
    
    if ! command_exists npm; then
        echo -e "${RED}npm is not installed${NC}"
        exit 1
    fi
    
    echo -e "${GREEN}✓ Prerequisites check passed${NC}"
    
    # Run setup tasks
    setup_environment
    install_dependencies
    setup_images
    clear_cache
    check_database
    
    # Run tests if not skipped
    if [ "$SKIP_TESTS" = false ]; then
        run_tests
    fi
    
    # Start server unless setup-only mode
    if [ "$SETUP_ONLY" = false ]; then
        if [ "$PROD_MODE" = true ]; then
            echo -e "\n${YELLOW}Building for production...${NC}"
            npm run build
            echo -e "\n${YELLOW}Starting production server...${NC}"
            npm start
        else
            start_server
        fi
    else
        echo -e "\n${GREEN}Setup completed successfully!${NC}"
        echo -e "${BLUE}To start the server manually, run: npm run dev:mock${NC}"
        echo -e "${BLUE}Server will be available at: http://localhost:3006${NC}"
    fi
}

# Handle script interruption
trap 'echo -e "\n${YELLOW}Shutting down...${NC}"; exit 0' INT TERM

# Make sure we're in the right directory
cd "$(dirname "$0")"

# Run main function with all arguments
main "$@" 