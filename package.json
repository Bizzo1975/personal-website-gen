{
  "name": "personal-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "cd testing && jest",
    "test:watch": "cd testing && jest --watch",
    "test:coverage": "cd testing && jest --coverage",
    "test:ci": "cd testing && jest --ci --coverage",
    "dev": "next dev",
    "dev:docker": "next dev -H 0.0.0.0 -p 3006",
    "dev:mock": "rimraf .next && cross-env MOCK_DATA=true next dev -p 3006",
    "dev:compose": "docker-compose up --build",
    "dev:docker:detached": "docker-compose up --build -d",
    "docker:stop": "docker-compose down",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "docker:logs": "docker-compose logs -f app",
    "docker:shell": "docker-compose exec app sh",
    "setup:images": "echo 'Using existing media files from database'",
    "download:images": "node scripts/setup/download-real-images.js",
    "setup:all": "npm run download:images && npm run setup:images",
    "build": "next build",
    "postinstall": "npx update-browserslist-db@latest || true",
    "start": "next start -p 3006",
    "lint": "next lint",
    "cypress": "cd testing && cypress open",
    "cypress:headless": "cd testing && cypress run",
    "test:e2e": "start-server-and-test dev:mock http://localhost:3006 cypress",
    "test:e2e:ci": "start-server-and-test dev:mock http://localhost:3006 cypress:headless",
    "test:e2e:docker": "start-server-and-test dev:docker http://localhost:3006 cypress:headless",
    "analyze": "ANALYZE=true npm run build",
    "lighthouse": "node scripts/run-lighthouse.js",
    "performance:audit": "start-server-and-test dev:mock http://localhost:3006 lighthouse",
    "accessibility": "node scripts/check-accessibility.js",
    "a11y:audit": "start-server-and-test dev:mock http://localhost:3006 accessibility"
  },
  "dependencies": {
    "@auth/pg-adapter": "^1.0.0",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@headlessui/react": "^2.2.3",
    "@heroicons/react": "^2.2.0",
    "@sendgrid/mail": "^8.1.3",
    "@tailwindcss/typography": "^0.5.16",
    "@types/archiver": "^6.0.3",
    "@types/nodemailer": "^6.4.17",
    "@types/react-big-calendar": "^1.16.2",
    "@types/uuid": "^10.0.0",
    "archiver": "^7.0.1",
    "aws4": "^1.13.2",
    "axios": "^1.10.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "dompurify": "^3.2.6",
    "dotenv": "^16.5.0",
    "easymde": "^2.20.0",
    "framer-motion": "^12.12.1",
    "ioredis": "^5.8.2",
    "jsdom": "^26.1.0",
    "marked": "^16.4.1",
    "next": "^15.4.1",
    "next-auth": "^4.24.11",
    "next-mdx-remote": "^4.4.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.10.1",
    "pg": "^8.16.3",
    "react": "^18.2.0",
    "react-big-calendar": "^1.19.4",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.56.4",
    "react-icons": "^5.5.0",
    "react-simplemde-editor": "^5.2.0",
    "sharp": "^0.34.4",
    "tailwind-merge": "^3.3.0",
    "tough-cookie": "^5.1.2",
    "typo-js": "^1.2.5",
    "uuid": "^11.1.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.48",
    "@types/pg": "^8.10.9",
    "@types/react": "18.3.21",
    "@types/react-dom": "^18.3.7",
    "@types/react-google-recaptcha": "^2.1.9",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.10.3",
    "chalk": "^5.4.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.54.0",
    "eslint-config-next": "^15.4.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.31",
    "rimraf": "^5.0.5",
    "start-server-and-test": "^2.0.12",
    "tailwindcss": "^3.3.5",
    "typescript": "5.8.3"
  },
  "description": "A modern, responsive personal website built with Next.js, TypeScript, and Tailwind CSS. This website serves as a portfolio, blog, and project showcase.",
  "main": "next.config.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "overrides": {
    "cookie": "^0.7.0",
    "quill": "^2.0.0",
    "glob": "^10.3.10",
    "rimraf": "^5.0.5"
  }
}
