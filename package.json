{
  "name": "personal-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "cd testing && jest",
    "test:watch": "cd testing && jest --watch",
    "test:coverage": "cd testing && jest --coverage",
    "test:ci": "cd testing && jest --ci --coverage",
    "dev": "rimraf .next && cross-env FRONTEND_PORT=3007 next dev -p 3007",
    "dev:mock": "rimraf .next && cross-env MOCK_DATA=true FRONTEND_PORT=3007 next dev -p 3007",
    "dev:windows": "rimraf .next && set FRONTEND_PORT=3007 && next dev -p 3007",
    "dev:mock:windows": "rimraf .next && set MOCK_DATA=true && set FRONTEND_PORT=3007 && next dev -p 3007",
    "dev:docker:safe": "cross-env MOCK_DATA=true FRONTEND_PORT=3007 next dev -p 3007",
    "dev:docker": "docker-compose up --build",
    "dev:docker:detached": "docker-compose up --build -d",
    "docker:stop": "docker-compose down",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "docker:logs": "docker-compose logs -f frontend",
    "docker:shell": "docker-compose exec frontend sh",
    "setup:images": "node scripts/setup/ensure-placeholder-images.js",
    "download:images": "node scripts/setup/download-real-images.js",
    "setup:all": "npm run download:images && npm run setup:images",
    "seed:admin": "node scripts/setup/init-admin.js",
    "seed:pages": "node scripts/setup/init-pages.js",
    "seed:full": "node scripts/setup/seed-full-database.js",
    "seed:complete": "npm run setup:all && npm run seed:full",
    "dev:safe": "npm run setup:images && npm run dev:mock",
    "dev:seeded": "npm run seed:complete && npm run dev:mock",
    "dev:complete": "npm run setup:all && npm run dev:mock",
    "build": "cross-env FRONTEND_PORT=3007 next build",
    "start": "cross-env FRONTEND_PORT=3007 next start -p 3007",
    "start:windows": "set FRONTEND_PORT=3007 && next start -p 3007",
    "lint": "next lint",
    "cypress": "cd testing && cypress open",
    "cypress:headless": "cd testing && cypress run",
    "test:e2e": "start-server-and-test dev:mock http://localhost:3007 cypress",
    "test:e2e:ci": "start-server-and-test dev:mock http://localhost:3007 cypress:headless",
    "test:e2e:docker": "start-server-and-test dev:docker http://localhost:3007 cypress:headless",
    "analyze": "ANALYZE=true npm run build",
    "lighthouse": "node scripts/run-lighthouse.js",
    "performance:audit": "start-server-and-test dev:mock http://localhost:3007 lighthouse",
    "accessibility": "node scripts/check-accessibility.js",
    "a11y:audit": "start-server-and-test dev:mock http://localhost:3007 accessibility"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.9.0",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@headlessui/react": "^2.2.3",
    "@tailwindcss/typography": "^0.5.16",
    "@types/uuid": "^10.0.0",
    "aws4": "^1.13.2",
    "bcrypt": "^5.1.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.6",
    "dotenv": "^16.5.0",
    "easymde": "^2.20.0",
    "framer-motion": "^12.12.1",
    "jsdom": "^26.1.0",
    "mongodb": "^6.16.0",
    "mongoose": "^8.14.1",
    "next": "^14.0.3",
    "next-auth": "^4.24.11",
    "next-mdx-remote": "^4.4.1",
    "next-themes": "^0.4.6",
    "node-fetch": "^2.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.56.4",
    "react-icons": "^5.5.0",
    "react-quill": "^2.0.0",
    "react-simplemde-editor": "^5.2.0",
    "tailwind-merge": "^3.3.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.1",
    "@next/bundle-analyzer": "^15.3.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.48",
    "@types/react": "18.3.21",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.10.3",
    "chalk": "^5.4.1",
    "cross-env": "^7.0.3",
    "cypress": "^14.3.3",
    "eslint": "^8.54.0",
    "eslint-config-next": "14.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.31",
    "puppeteer": "^24.9.0",
    "rimraf": "^5.0.5",
    "start-server-and-test": "^2.0.12",
    "tailwindcss": "^3.3.5",
    "typescript": "5.8.3"
  },
  "description": "A modern, responsive personal website built with Next.js, TypeScript, and Tailwind CSS. This website serves as a portfolio, blog, and project showcase.",
  "main": "next.config.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
