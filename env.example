# Environment Configuration for Personal Website
# Copy this file to .env.local and update with your actual values

# Port Configuration - Updated for Docker and Windows compatibility
FRONTEND_PORT=3007
BACKEND_PORT=4007
DATABASE_PORT=5437

# Base URLs (automatically constructed from ports)
FRONTEND_URL=http://localhost:3007
BACKEND_URL=http://localhost:4007
API_URL=http://localhost:3007/api

# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3007
NEXTAUTH_URL_INTERNAL=http://localhost:3007

# Database Configuration
# Currently using PostgreSQL - uncomment MongoDB if switching back
DATABASE_TYPE=postgresql

# PostgreSQL Configuration (current setup)
POSTGRES_HOST=localhost
POSTGRES_PORT=5437
POSTGRES_DB=personal_website
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_SSL=false
DATABASE_URL=postgresql://postgres:your-postgres-password@localhost:5437/personal_website

# MongoDB Configuration (alternative setup)
# DATABASE_TYPE=mongodb
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/personal-website?retryWrites=true&w=majority
# DB_NAME=personal_website

# Development Settings
NODE_ENV=development
MOCK_DATA=true

# Windows & Docker specific settings
# Enable file polling for Windows development (fixes HMR issues in Docker)
NEXT_WEBPACK_USEPOLLING=1
WATCHPACK_POLLING=true

# Docker settings
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Upload Configuration
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880

# Optional: Production Settings
# NODE_ENV=production
# MOCK_DATA=false
# NEXTAUTH_URL=https://your-production-domain.com

# Security Settings (for production)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=900000

# Logging
# LOG_LEVEL=info
# LOG_FILE=./logs/application.log 