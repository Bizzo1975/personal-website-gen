# Environment Configuration for Personal Website
# Copy this file to .env.local and update with your actual values

# Port Configuration - Docker development setup
FRONTEND_PORT=3000

# Base URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# NextAuth Configuration (simplified)
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_URL_INTERNAL=http://localhost:3000

# Production URLs - CloudFlare Domain (uncomment for production)
# NEXTAUTH_URL=https://willworkforlunch.com
# NEXT_PUBLIC_SITE_URL=https://willworkforlunch.com
# DOMAIN_NAME=willworkforlunch.com

# Database Configuration - PostgreSQL (REQUIRED - no mock data fallback)
DATABASE_URL=postgresql://postgres:password@localhost:5436/personal_website

# PostgreSQL Database Settings
POSTGRES_DB=personal_website
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5436

# Redis Configuration (optional - for session storage and caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Development Settings
NODE_ENV=development

# Email Configuration (for newsletters and access requests)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Production Email Configuration - CloudFlare Domain (uncomment for production)
# ADMIN_EMAIL=admin@willworkforlunch.com
# CONTACT_EMAIL=contact@willworkforlunch.com

# Cron job authentication for scheduled content publishing
CRON_SECRET=your-secure-cron-secret-key-change-in-production

# Docker file watching settings (optional)
# Only needed if using Docker Desktop on Windows - NOT needed on Linux/Ubuntu
# On Linux/Ubuntu, file watching works natively without these settings
# NEXT_WEBPACK_USEPOLLING=1
# WATCHPACK_POLLING=true

# Docker settings
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Upload Configuration
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760

# Security Settings (for production)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=900000

# CloudFlare Configuration (for production)
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ZONE_ID=your-zone-id-for-willworkforlunch-com

# Production Settings (uncomment for production)
# NODE_ENV=production
# NEXTAUTH_URL=https://willworkforlunch.com

# Logging
# LOG_LEVEL=info
# LOG_FILE=./logs/application.log 
