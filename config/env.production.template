# Production Environment Configuration Template
# Copy this file to .env.production and update with your actual values
# 
# IMPORTANT SECURITY NOTES:
# 1. Generate NEW secure passwords for production (DO NOT reuse dev passwords)
# 2. Never commit this file to version control (.env.production is in .gitignore)
# 3. Set file permissions to 600: chmod 600 .env.production
# 4. All passwords must be different from development environment
# 5. Test all email functionality before going live

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=production

# Port Configuration - Production uses port 3000 (dev uses 3006)
FRONTEND_PORT=3000

# Base URLs - MUST use HTTPS and production domain
FRONTEND_URL=https://www.willworkforlunch.com
API_URL=https://www.willworkforlunch.com/api
NEXTAUTH_URL=https://www.willworkforlunch.com
NEXTAUTH_URL_INTERNAL=https://www.willworkforlunch.com
NEXT_PUBLIC_SITE_URL=https://www.willworkforlunch.com
DOMAIN_NAME=www.willworkforlunch.com

# NextAuth Secret - GENERATE NEW: openssl rand -hex 32
# MUST be different from development secret
NEXTAUTH_SECRET=YOUR_NEW_32_CHARACTER_SECRET_HERE_GENERATE_WITH_OPENSSL_RAND_HEX_32

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Connection String - Update password in connection string
DATABASE_URL=postgresql://postgres:YOUR_SECURE_POSTGRES_PASSWORD@db:5432/personal_website

# PostgreSQL Database Settings
POSTGRES_DB=personal_website
POSTGRES_USER=postgres
# PostgreSQL Password - GENERATE NEW: openssl rand -base64 32
# MUST be different from development password (admin123)
POSTGRES_PASSWORD=YOUR_SECURE_POSTGRES_PASSWORD
# Note: Port 5432 is internal to Docker network (not exposed externally)

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis Connection URL - Uses internal Docker network hostname
REDIS_URL=redis://redis:6379
# Redis Password - GENERATE NEW: openssl rand -base64 32
# MUST be different from development password
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD

# =============================================================================
# EMAIL CONFIGURATION (Choose ONE option - uncomment the one you use)
# =============================================================================

# Option A: SendGrid (Recommended for production)
# SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
# FROM_EMAIL=admin@willworkforlunch.com
# ADMIN_EMAIL=admin@willworkforlunch.com
# CONTACT_EMAIL=contact@willworkforlunch.com

# Option B: Gmail SMTP (Alternative - requires Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@willworkforlunch.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
ADMIN_EMAIL=admin@willworkforlunch.com
CONTACT_EMAIL=contact@willworkforlunch.com
FROM_EMAIL=admin@willworkforlunch.com

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Cron Secret - For scheduled content publishing authentication
# GENERATE NEW: openssl rand -base64 32
# MUST be different from development secret
CRON_SECRET=YOUR_SECURE_CRON_SECRET_KEY_CHANGE_IN_PRODUCTION

# =============================================================================
# UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760

# =============================================================================
# CLOUDFLARE CONFIGURATION (Optional - for advanced features)
# =============================================================================
# Uncomment if using Cloudflare API for DNS management or other features
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ZONE_ID=your-zone-id-for-willworkforlunch-com

# =============================================================================
# MONITORING & ANALYTICS (Optional)
# =============================================================================
# Uncomment if using these services
# GOOGLE_ANALYTICS_ID=your-google-analytics-id
# SENTRY_DSN=your-sentry-dsn-for-error-tracking

# =============================================================================
# PERFORMANCE CONFIGURATION (Optional)
# =============================================================================
# Enable compression and caching
# COMPRESSION_ENABLED=true
# CACHE_ENABLED=true

# =============================================================================
# LOGGING CONFIGURATION (Optional)
# =============================================================================
# LOG_LEVEL=info
# LOG_FILE=./logs/application.log

# =============================================================================
# BACKUP CONFIGURATION (Optional - for automated backups)
# =============================================================================
# BACKUP_RETENTION_DAYS=30
# BACKUP_SCHEDULE=0 2 * * *

# =============================================================================
# SECURITY HEADERS (Optional - Production defaults)
# =============================================================================
# SECURITY_HEADERS_ENABLED=true
# CORS_ORIGIN=https://www.willworkforlunch.com

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================
# 
# CRITICAL: Before deploying to production:
# 
# 1. Generate ALL new passwords/secrets (do not reuse dev values):
#    - NEXTAUTH_SECRET: openssl rand -hex 32
#    - POSTGRES_PASSWORD: openssl rand -base64 32
#    - REDIS_PASSWORD: openssl rand -base64 32
#    - CRON_SECRET: openssl rand -base64 32
#
# 2. Update all URLs to use HTTPS and production domain:
#    - Replace localhost with www.willworkforlunch.com
#    - Use https:// not http://
#
# 3. Configure email (choose SendGrid OR Gmail SMTP):
#    - SendGrid: Uncomment Option A, add API key
#    - Gmail: Uncomment Option B, use App Password (not regular password)
#
# 4. Verify database backup is ready for migration:
#    - Location: backups/database/database_backup_YYYYMMDD_HHMMSS.sql.gz
#    - Test restore on a test database first
#
# 5. After creating .env.production on server:
#    - Set permissions: chmod 600 .env.production
#    - Verify it's NOT committed to git
#
# 6. Database migration steps (see Step 7A in deployment guide):
#    - Transfer backup to production server
#    - Ensure database container is running
#    - Restore using: docker-compose exec -T db psql -U postgres -d personal_website < backup.sql
#
# 7. Verify all services are running:
#    - docker-compose -f docker-compose.prod.yml ps
#    - All containers should show "Up" status
#
# 8. Test application:
#    - Local: curl http://127.0.0.1:3000
#    - Public: https://www.willworkforlunch.com
#    - Verify HTTPS, SSL certificate, all pages load
#
# 9. Security verification:
#    - DMZ cannot reach LAN (192.168.1.x) - ping should fail
#    - DMZ cannot reach Management (192.168.10.x) - ping should fail
#    - DMZ can reach internet - ping 8.8.8.8 should succeed
#
# For full deployment instructions, see: Proxmox_Web_Hosting_Master_Plan_Full.md
